<robot name="pendulum">

  <link name="base">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </visual>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0 -0.5"/>
      <geometry>
        <cylinder length="1.0" radius="0.02"/>
      </geometry>
    </visual>
  </link>

  <joint name="hinge" type="revolute">
    <parent link="base"/>
    <child link="link1"/>

    <!-- pivot noktası -->
    <origin xyz="0 0 0"/>

    <axis xyz="0 1 0"/>

    <limit effort="10" velocity="5" lower="-3.14" upper="3.14"/>
  </joint>

  <ros2_control name="MujocoSystem" type="system">
    <hardware>
      <plugin>mujoco_pendulum::MujocoSystem</plugin>
    </hardware>

    <joint name="hinge">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

</robot>