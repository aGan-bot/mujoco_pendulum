<mujoco model="pendulum">
  <compiler inertiafromgeom="false" angle="radian"/>

  <option gravity="0 0 -9.81" timestep="0.002"/>

  <worldbody>

    <body name="base" pos="0 0 0">
      
      <body name="link1" pos="0 0 0">
        <inertial pos="0 0 -0.5" mass="1.0" diaginertia="0.09 0.09 0.001"/>
        
        <joint
          name="hinge"
          type="hinge"
          axis="0 1 0"
          limited="true"
          range="-3.1416 3.1416"
          damping="0.01"/>

        <geom type="capsule" fromto="0 0 0 0 0 -1" size="0.02" density="0"/>
        <body name="tip_mass" pos="0 0 -1">
          <inertial pos="0 0 0" mass="0.7" diaginertia="0.002 0.002 0.002"/>
          <geom
            type="sphere"
            size="0.06"
            density="0"
            rgba="0.9 0.2 0.2 1"
            contype="0"
            conaffinity="0"/>
        </body>

      </body>

    </body>

  </worldbody>

  <actuator>
    <motor joint="hinge" ctrlrange="-20 20"/>
  </actuator>

</mujoco>
